# ============================================================
# AIM DENTAL CRM v3.0 — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=4000
FRONTEND_URL=https://aim-crm-frontend.vercel.app

# Database — Supabase PostgreSQL (Session Pooler connection string)
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# JWT Authentication
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_EXPIRY=24h

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Aim Dental CRM <noreply@aimdentallab.com>
ALERT_EMAIL=your-alert-email@gmail.com

# Lead Capture — API key for POST /api/leads/capture
# Used by server-to-server integrations (social webhooks via Zapier/Make)
LEAD_CAPTURE_API_KEY=aim-dental-2026-secret

# Web Leads — POST /api/web-leads (no API key; called from browser JS on the
# marketing website's Contact and Scanner Program forms).
# Contact form recipient; defaults to media@aimdentallab.com if unset (set
# "for now" per the client — may change).
CONTACT_FORM_EMAIL=media@aimdentallab.com
# Scanner Program form recipient; defaults to digital@aimdentallab.com if unset.
WEB_LEADS_EMAIL=digital@aimdentallab.com

# Implant Intake — POST /api/implant-intake ("Submit Case to AIM" on the
# Implant Case Intake Protocol page). Recipient for the completed
# questionnaire; defaults to digital@aimdentallab.com if unset.
IMPLANT_INTAKE_EMAIL=digital@aimdentallab.com

# First Admin User — only used by scripts/seed-admin.js
ADMIN_EMAIL=admin@aimdentallab.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
