# ============================================================
# AIM DENTAL CRM v3.0 — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=4000
FRONTEND_URL=https://aim-crm-frontend.vercel.app

# Database — Supabase PostgreSQL (Session Pooler connection string)
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# JWT Authentication
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_EXPIRY=24h

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Aim Dental CRM <noreply@aimdentallab.com>
ALERT_EMAIL=your-alert-email@gmail.com

# Lead Capture — API key for POST /api/leads/capture
# Used by the website embed and social webhooks (Zapier/Make)
LEAD_CAPTURE_API_KEY=aim-dental-2026-secret

# First Admin User — only used by scripts/seed-admin.js
ADMIN_EMAIL=admin@aimdentallab.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
