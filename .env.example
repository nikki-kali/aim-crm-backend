# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# Database — get from Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# Auth
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRY=24h

# Email (SMTP) — Gmail example: use an App Password, not your real password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# Where to send automated alerts
ALERT_EMAIL=admin@aimdentallab.com

# Lead capture embed API key — set a strong random string
LEAD_CAPTURE_API_KEY=replace-with-random-key

# Admin seed (used by scripts/seed-admin.js)
ADMIN_EMAIL=admin@aimdentallab.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
